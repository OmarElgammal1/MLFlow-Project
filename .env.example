# Copy to .env and fill in your Axiom ingest token + dataset name.
AXIOM_TOKEN=your-axiom-ingest-token
AXIOM_DATASET=churn-api
# Region-specific Axiom API URL. EU datasets MUST set this; US datasets can omit.
#   US (default): https://api.axiom.co
#   EU:           https://api.eu.axiom.co
AXIOM_URL=https://api.eu.axiom.co

# Load test target (used by `uv run locust -f loadtest/locustfile.py`).
LOCUST_HOST=http://localhost:8000
